# Copy this to .env and fill in your values

# SQLite database path
# Local:      DATABASE_URL=file:./tada-cms.db
# Production: DATABASE_URL=file:/home/ubuntu/tada-cms/tada-cms.db
DATABASE_URL=file:./tada-cms.db

# Payload JWT secret — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=YOUR_LONG_RANDOM_SECRET_HERE

# Full public URL — no trailing slash
# Local:      http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Bootstrap secret for /api/promote-admin (delete that route after first use)
PROMOTE_ADMIN_SECRET=tada-bootstrap-2026

# Cron and preview secrets (optional)
CRON_SECRET=YOUR_CRON_SECRET_HERE
PREVIEW_SECRET=YOUR_SECRET_HERE
